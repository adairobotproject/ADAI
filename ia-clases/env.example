# ======================
#  CONFIGURACIÓN DE API KEYS
# ======================
# Copia este archivo a .env y completa con tus API keys reales

# OpenAI API Key
# Obtén tu API key en: https://platform.openai.com/api-keys
OPENAI_API_KEY=tu_openai_api_key_aqui

# ElevenLabs API Keys
# Obtén tus API keys en: https://elevenlabs.io/app/settings/api-keys
# Primera API key (principal)
ELEVENLABS_API_KEY=tu_elevenlabs_api_key_aqui

# Segunda API key (respaldo, opcional)
ELEVENLABS_API_KEY_2=tu_elevenlabs_api_key_2_aqui
